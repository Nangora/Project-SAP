<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form">

    <Dialog id="giDialog" title="Thực hiện Xuất kho">
        <content>
            <f:SimpleForm id="_IDGenSimpleForm" editable="true" layout="ResponsiveGridLayout">
                <f:content>
    <Label id="_IDGenLabel12" text="Sales Order (VBELN)" required="true" />
    <Input id="inputVBELN" placeholder="e.g. 0000006142" />

    <Label id="_IDGenLabel13" text="Item Number (POSNR)" required="true" />
    <Input id="inputPOSNR" value="000010" />

    <Label id="_IDGenLabel14" text="Delivery Quantity (LFIMG)" required="true" />
    <Input id="inputLFIMG" type="Number" placeholder="Enter quantity..." />

    <Label id="_IDGenLabel15" text="Plant (WERKS)" required="true" />
    <Input id="inputWERKS" value="FU24" />

    <Label id="_IDGenLabel16" text="Storage Location (LGORT)" required="true" />
    <Input id="inputLGORT" value="TG01" />

    <Label id="_IDGenLabel18" text="Posting Date (BUDAT)" required="true" />
    <DatePicker id="inputBUDAT" displayFormat="dd/MM/yyyy" valueFormat="yyyyMMdd" />
</f:content>
            </f:SimpleForm>
        </content>

        <beginButton>
            <Button id="_IDGenButton11" text="Xác nhận Xuất" type="Emphasized" press=".onSaveGI" />
        </beginButton>

        <endButton>
            <Button id="_IDGenButton12" text="Hủy" press=".onCloseGIDialog" />
        </endButton>
    </Dialog>

</core:FragmentDefinition>