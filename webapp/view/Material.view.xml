<mvc:View
    controllerName="zsupplychain.supplychainsystem.controller.Material"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    displayBlock="true">

    <Page id="matPage" title="Danh sách Material" showNavButton="true" navButtonPress=".onNavBack">
        <content>
            <VBox id="matBox" class="sapUiSmallMargin">
                <Toolbar id="filterToolbar" class="sapUiSmallMarginBottom">
                    <Label text="Material" id="matLabel"/>
                    <Input 
                        id="matInput" 
                        width="200px" 
                        placeholder="Nhập mã Material..." 
                        submit=".onFilter"/> 
                    <Button id="_IDGenButton" 
                        text="Filter" 
                        icon="sap-icon://filter" 
                        press=".onFilter" 
                        type="Emphasized"/>
                    <Button id="_IDGenButton2" 
                        text="Clear" 
                        icon="sap-icon://decline" 
                        press=".onClear"/>
                    <ToolbarSpacer id="_IDGenToolbarSpacer" />
                    <Button
                        id="matRefreshBtn"
                        text="Tải lại"
                        icon="sap-icon://refresh"
                        press=".onRefresh" />
                </Toolbar>

                <Table
                    id="matTable"
                    width="auto"
                    growing="true"
                    growingThreshold="20"
                    noDataText="Không có dữ liệu material"
                    items="{path: '/MaterialSet'}"> <columns>
                        <Column id="matCodeCol"><Text id="_IDGenText13" text="Mã Material" /></Column>
                        <Column id="matNameCol"><Text id="_IDGenText14" text="Tên Material" /></Column>
                        <Column id="matUnitCol"><Text id="_IDGenText15" text="Đơn vị tính" /></Column>
                    </columns>

                    <items>
                        <ColumnListItem id="matItem" type="Active">
                            <cells>
                                <Text id="_IDGenText16" text="{Matnr}" />
                                <Text id="_IDGenText17" text="{Maktx}" />
                                <Text id="_IDGenText18" text="{Meins}" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
    </Page>
</mvc:View>