<mvc:View
    controllerName="zsupplychain.supplychainsystem.controller.GoodsIssue"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    displayBlock="true">
    <Page id="giPage" title="Danh sách Xuất kho (Goods Issue)" showNavButton="true" navButtonPress=".onNavBack">
        <content>
            <Table id="giTable" items="{/GoodsIssueSet}" growing="true" growingThreshold="20">
                <headerToolbar>
                    <OverflowToolbar id="_IDGenOverflowToolbar1">
                        <Title id="_IDGenTitle1" text="Danh sách Goods Issue" />
                        <ToolbarSpacer id="_IDGenToolbarSpacer1" />
                        <Button id="_IDGenButton9" text="Thực hiện Xuất kho" icon="sap-icon://shipping-status" press=".onOpenGIDialog" type="Emphasized" />
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                    <Column id="_IDGenColumn12"><Text id="_IDGenText40" text="Sales Order" /></Column>
                    <Column id="_IDGenColumn20"><Text id="_IDGenText41" text="Item" /></Column>
                    <Column id="_IDGenColumn21" hAlign="End"><Text id="_IDGenText42" text="Số lượng" /></Column>
                    <Column id="_IDGenColumn22"><Text id="_IDGenText43" text="Ngày" /></Column>
                    <Column id="_IDGenColumn23"><Text id="_IDGenText44" text="Nhà máy / Kho" /></Column>
                    <Column id="_IDGenColumn24"><Text id="_IDGenText45" text="Trạng thái" /></Column>
                </columns>
                <items>
                    <ColumnListItem id="_IDGenColumnListItem3">
                        <cells>
                            <ObjectIdentifier id="_IDGenObjectIdentifier2" title="{SalesOrder}" />
                            <Text id="_IDGenText46" text="{SalesItem}" />
                            <ObjectNumber id="_IDGenObjectNumber3" number="{Quantity}" unit="{UoM}" />
                            <Text id="_IDGenText47" text="{
                                path: 'PostingDate',
                                type: 'sap.ui.model.type.Date',
                                formatOptions: { pattern: 'dd/MM/yyyy' }
                            }" />
                            <Text id="_IDGenText48" text="{Plant} / {StorageLoc}" />
                            <ObjectStatus id="_IDGenObjectStatus" 
                                text="{Message}" 
                                state="{= ${MatDoc} === '' ? 'Warning' : 'Success' }" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>