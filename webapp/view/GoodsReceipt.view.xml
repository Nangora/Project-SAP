<mvc:View id="_IDGenView"
    controllerName="zsupplychain.supplychainsystem.controller.GoodsReceipt"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    displayBlock="true">
    
    <Page id="grPage" title="Lịch sử Nhập kho (Goods Receipt)" showNavButton="true" navButtonPress=".onNavBack">
        <content>
            <VBox id="_IDGenVBox1" class="sapUiSmallMargin">
                <Table id="grTable" items="{/GoodsReceiptSet}" growing="true" growingThreshold="20" width="auto" noDataText="Không có dữ liệu nhập kho">
                    <columns>
                        <Column id="_IDGenColumn5"><Text id="_IDGenText10" text="Mã phiếu (MBLNR)" /></Column>
                        <Column id="_IDGenColumn6"><Text id="_IDGenText11" text="Đơn hàng (EBELN)" /></Column>
                        <Column id="_IDGenColumn7"><Text id="_IDGenText12" text="Vật tư (MATNR)" /></Column>
                        <Column id="_IDGenColumn8"><Text id="_IDGenText19" text="Ngày (BUDAT)" /></Column>
                        <Column id="_IDGenColumn9" hAlign="End"><Text id="_IDGenText20" text="Số lượng (MENGE)" /></Column>
                        <Column id="_IDGenColumn10"><Text id="_IDGenText21" text="ĐVT" /></Column>
                        <Column id="_IDGenColumn11"><Text id="_IDGenText22" text="Plant" /></Column>
                    </columns>
                    <items>
                        <ColumnListItem id="_IDGenColumnListItem" type="Active">
                            <cells>
                                <ObjectIdentifier id="_IDGenObjectIdentifier1" title="{MBLNR}" text="Item: {EBELP}"/>
                                <Text id="_IDGenText23" text="{EBELN}" />
                                <Text id="_IDGenText24" text="{MATNR}" />
                                <Text id="_IDGenText25" text="{
                                    path: 'BUDAT', 
                                    type: 'sap.ui.model.type.DateTime', 
                                    formatOptions: { pattern: 'dd/MM/yyyy' }
                                }" />
                                <ObjectNumber id="_IDGenObjectNumber" number="{MENGE}" />
                                <Text id="_IDGenText26" text="{MEINS}" />
                                <Text id="_IDGenText27" text="{WERKS}" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
    </Page>
</mvc:View>